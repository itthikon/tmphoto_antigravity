PORT=3000
NODE_ENV=development

# Database Settings
DB_TYPE=sqlite
DB_FILENAME=./src/db/database.sqlite

# JWT configuration for Admin Auth
JWT_SECRET=photostudio_admin_secret_key_123!

# LINE Official Account Settings
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET
LINE_LIFF_ID=YOUR_LINE_LIFF_ID

# Cloudflare R2 Integration Settings
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_ACCESS_KEY_ID=YOUR_CLOUDFLARE_ACCESS_KEY_ID
CLOUDFLARE_SECRET_ACCESS_KEY=YOUR_CLOUDFLARE_SECRET_ACCESS_KEY
CLOUDFLARE_R2_BUCKET_NAME=YOUR_CLOUDFLARE_R2_BUCKET_NAME

# Easyslip API Key (Use 'mock' for local offline testing)
EASYSLIP_API_KEY=mock
